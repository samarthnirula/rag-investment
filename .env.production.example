# ── Production env checklist for the Render backend ───────────────────────
# Copy each value into Render's dashboard (Environment tab) — do NOT commit
# a filled-in version of this file. Grouped by where the value comes from.

# ── 1. Supabase (Project Settings → Database → Connection string → "Pooled") ──
DATABASE_URL=

# ── 2. Anthropic (console.anthropic.com → API Keys) ───────────────────────
ANTHROPIC_API_KEY=

# ── 3. Voyage AI (dash.voyageai.com → API Keys) — optional but recommended ──
# Setting this skips loading sentence-transformers/torch at backend startup,
# which keeps the Render free-tier container lighter and faster to boot.
# Leave blank to fall back to a local embedding model instead (heavier).
VOYAGE_API_KEY=
EMBEDDING_MODEL=voyage-law-2

GENERATION_MODEL=claude-sonnet-4-6
RETRIEVAL_TOP_K=8

# ── 4. Firebase (console.firebase.google.com) ─────────────────────────────
# Project Settings → Service Accounts → Generate new private key → paste the
# ENTIRE downloaded JSON file's content as the value of this one var:
FIREBASE_SERVICE_ACCOUNT_JSON=
# Project Settings → General → Web API Key:
FIREBASE_API_KEY=

# ── 5. Generated locally ────────────────────────────────────────────────────
# Run `python scripts/generate_secrets.py` and paste the printed value here —
# deliberately NOT filled in in this file (it's tracked by git; the .env file
# itself is gitignored and is where the real value belongs).
ADMIN_API_KEY=

# ── 6. Your domain, once purchased + pointed at Vercel ─────────────────────
# Must be the exact frontend origin or CORS blocks every request.
APP_URL=https://your-domain.com

# ── 7. Demo portal access codes — make these up, hand them to testers ──────
DEMO_ACCESS_CODE_USER1=
DEMO_ACCESS_CODE_USER2=
DEMO_ACCESS_CODE_USER3=

# ── 8. Optional — safe to leave blank for launch ───────────────────────────
REDIS_URL=
ZEP_ENABLED=false
CHUNK_SIZE_TOKENS=400
CHUNK_OVERLAP_TOKENS=50
